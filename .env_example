# MySQL Configuration
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3307
MYSQL_ROOT_PASSWORD=rootpassword
MYSQL_USER=appuser
MYSQL_PASSWORD=apppassword
MYSQL_DB=verifishelf

# Redis Configuration
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# FastAPI Settings
APP_PORT=8000
DEBUG=True

# Auth
AUTH_SECRET=dev-secret-change-me
DEMO_AUTH_EMAIL=admin@verifishelf.local
DEMO_AUTH_PASSWORD=admin123
AUTH_TOKEN_TTL_SECONDS=86400

# Daraz MVP crawl scheduler (Celery Beat)
CRAWL_COUNTRY_CODE=LK
CRAWL_DEMO_MODE=true
CRAWL_SCHEDULER_TICK_SECONDS=30
CRAWL_DEMO_INTERVAL_STARTER=120
CRAWL_DEMO_INTERVAL_GROWTH=60
CRAWL_DEMO_INTERVAL_ENTERPRISE=30
CRAWL_INTERVAL_STARTER=3600
CRAWL_INTERVAL_GROWTH=1800
CRAWL_INTERVAL_ENTERPRISE=600

# CORS (comma-separated origins)
CORS_ALLOW_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
CORS_ALLOW_ORIGIN_REGEX=^https?://(localhost|127\.0\.0\.1|0\.0\.0\.0|(?:10|192\.168|172\.(?:1[6-9]|2\d|3[0-1]))\.\d{1,3}\.\d{1,3})(?::3000)$
